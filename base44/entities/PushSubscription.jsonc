{
  "name": "PushSubscription",
  "type": "object",
  "properties": {
    "endpoint": {
      "type": "string",
      "description": "Push service endpoint URL"
    },
    "p256dh": {
      "type": "string"
    },
    "auth": {
      "type": "string"
    },
    "device_label": {
      "type": "string",
      "description": "Optional user agent / device description"
    }
  },
  "required": [
    "endpoint",
    "p256dh",
    "auth"
  ]
}