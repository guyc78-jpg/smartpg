{
  "name": "SchoolClass",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Class name",
      "minLength": 1,
      "maxLength": 120
    },
    "owner_email": {
      "type": "string",
      "format": "email",
      "maxLength": 254,
      "description": "Normalized account email used for tenant ownership",
      "rls": {
        "create": { "data.owner_email": "{{user.email}}" },
        "read": { "data.owner_email": "{{user.email}}" },
        "update": false,
        "delete": false
      }
    },
    "grade_level": {
      "type": "string",
      "description": "Grade level",
      "maxLength": 40
    },
    "gender_track": {
      "type": "string",
      "enum": [
        "boys",
        "girls"
      ],
      "default": "boys"
    },
    "homeroom_teacher": {
      "type": "string",
      "maxLength": 160
    },
    "student_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000,
      "default": 0
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active"
    },
    "homeroom_contacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "maxLength": 128 },
          "name": { "type": "string", "maxLength": 160 },
          "phone": { "type": "string", "maxLength": 32, "pattern": "^[+0-9() .-]*$" }
        }
      },
      "default": [],
      "rls": {
        "create": { "user_condition": { "id": "{{user.id}}" } },
        "read": { "data.owner_email": "{{user.email}}" },
        "update": {
          "$and": [
            { "data.owner_email": "{{user.email}}" },
            { "user_condition": { "role": "admin" } }
          ]
        }
      }
    }
  },
  "required": [
    "name",
    "owner_email"
  ],
  "rls": {
    "create": {
      "$and": [
        { "user_condition": { "id": "{{user.id}}" } },
        { "data.owner_email": "{{user.email}}" }
      ]
    },
    "read": { "data.owner_email": "{{user.email}}" },
    "update": { "data.owner_email": "{{user.email}}" },
    "delete": { "data.owner_email": "{{user.email}}" }
  }
}
