{
  "name": "SubstituteFill",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "period": {
      "type": "number"
    },
    "class_id": {
      "type": "string",
      "description": "Linked app class id, empty when free-text class"
    },
    "class_name": {
      "type": "string",
      "description": "Class display name (from list or free text)"
    },
    "subject": {
      "type": "string",
      "description": "Lesson subject/topic for the fill"
    },
    "location": {
      "type": "string",
      "description": "Location (hall, field...)"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_reported",
        "reported",
        "paid"
      ],
      "default": "not_reported"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "date",
    "class_name"
  ]
}